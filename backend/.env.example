# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=smads_db

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Safety Thresholds
CONTINUOUS_USAGE_THRESHOLD_MINUTES=180
DAILY_USAGE_THRESHOLD_MINUTES=480
SESSION_FREQUENCY_THRESHOLD=25
ADDICTION_INDEX_WARNING_THRESHOLD=65
ADDICTION_INDEX_CRITICAL_THRESHOLD=85
